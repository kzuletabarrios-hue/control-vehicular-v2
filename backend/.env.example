# Copiar este archivo como .env y completar los valores

# PostgreSQL / Supabase
# Formato: postgresql://usuario:contraseña@host:puerto/base_de_datos
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_PROYECTO.supabase.co:5432/postgres

# JWT
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_LARGA_32_CHARS_MINIMO

# Tiempo de vida de tokens
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
